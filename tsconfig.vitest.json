{
  "extends": "./tsconfig.app.json",
  "include": [
    "src/**/*",
    "src/**/__tests__/*",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ],
  "exclude": [],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.vitest.tsbuildinfo",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
