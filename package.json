{
  "name": "my-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Portfolio site for SW Engineer 김신건 (Koa)",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@unhead/vue": "^3.1.1",
    "@vueuse/core": "^14.3.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.35",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.13.10",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "^10.9.2",
    "jiti": "^2.5.1",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.3"
  }
}
